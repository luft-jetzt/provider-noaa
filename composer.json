{
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "ext-simplexml": "*",
    "luft-jetzt/luft-api-bundle": "^1.1",
    "symfony/console": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/yaml": "^8.0"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*",
    "symfony/polyfill-php83": "*",
    "symfony/polyfill-php84": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ],
    "phpstan": "phpstan analyse",
    "cs-fix": "php-cs-fixer fix --allow-unsupported-php-version=yes",
    "cs-check": "php-cs-fixer fix --dry-run --diff --allow-unsupported-php-version=yes",
    "test": "phpunit",
    "ci": ["@phpstan", "@cs-check", "@test"]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "^8.0"
    }
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.1"
  }
}
